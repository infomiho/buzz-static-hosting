# Buzz server
BUZZ_DOMAIN=buzz.example.com
GITHUB_CLIENT_ID=Iv1.example
GITHUB_CLIENT_SECRET=your-github-client-secret
# BUZZ_DATA_DIR=/data
# BUZZ_ANALYTICS_SECRET=replace-with-a-random-secret

# Deployment limits
BUZZ_MAX_ARCHIVE_BYTES=524288000
BUZZ_MAX_SITE_BYTES=524288000
BUZZ_MAX_SITE_FILES=10000
BUZZ_MAX_ARCHIVE_PATH_BYTES=1024

# Access control
# BUZZ_ALLOW_REGISTRATION=false
# BUZZ_ALLOWED_GITHUB_USERS=alice,bob

# Optional custom domain control plane
# BUZZ_CUSTOM_DOMAINS_ENABLED=true
# BUZZ_TRAEFIK_CONTROL_TOKEN=replace-with-a-random-secret
# BUZZ_TRAEFIK_CONTROL_PORT=8081
# BUZZ_TRAEFIK_API_URL=http://coolify-proxy:8082/api
# BUZZ_TRAEFIK_API_AUTHORIZATION=Bearer replace-with-a-random-secret
# BUZZ_TRAEFIK_HTTPS_ENTRYPOINT=https
# BUZZ_TRAEFIK_SERVICE=buzz@docker
# BUZZ_CUSTOM_DOMAIN_OPERATOR_TOKEN=replace-with-a-random-secret
# BUZZ_MAX_CUSTOM_DOMAINS_PER_SITE=5
# BUZZ_MAX_CUSTOM_DOMAINS_PER_USER=20
# BUZZ_MAX_CUSTOM_DOMAINS_SERVER_WIDE=1000
# BUZZ_CUSTOM_DOMAIN_INGRESS_IPS=93.184.216.34
# BUZZ_CUSTOM_DOMAIN_ORIGIN_HOST=coolify-proxy
# BUZZ_TRAEFIK_CERT_RESOLVER=buzz-custom
# BUZZ_CUSTOM_DOMAIN_RECONCILE_SECONDS=5

# Standalone Docker Compose deployment
CF_API_TOKEN=your-cloudflare-api-token
ACME_EMAIL=admin@example.com
# BUZZ_CUSTOM_DOMAIN_ACME_CA_SERVER=https://acme-staging-v02.api.letsencrypt.org/directory

# Google Search Console
# BUZZ_GSC_CREDENTIALS={"type":"service_account",...}
# BUZZ_GSC_PROPERTY=sc-domain:buzz.example.com
