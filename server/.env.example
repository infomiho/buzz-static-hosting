# Buzz Server Configuration
BUZZ_DOMAIN=static.example.com
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Cloudflare API Token (for wildcard SSL certificates)
# Create at: Cloudflare Dashboard > My Profile > API Tokens > Create Token > Edit zone DNS
CF_API_TOKEN=your-cloudflare-api-token

# ACME email for Let's Encrypt certificate notifications
ACME_EMAIL=admin@example.com

# Google Search Console (optional, shows Google search terms per site)
# Service account key: either the JSON content on one line or a path to the file
# BUZZ_GSC_CREDENTIALS={"type":"service_account",...}
# Property to query, defaults to sc-domain:<BUZZ_DOMAIN>
# BUZZ_GSC_PROPERTY=sc-domain:static.example.com
